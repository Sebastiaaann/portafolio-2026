---
import Layout from '../../layouts/Layout.astro';
import { projectsData } from '../../data/projects';
import ProjectCaseStudy from '../../components/ProjectCaseStudy.astro';
import NotichilecCaseStudy from '../../components/NotichilecCaseStudy.astro';

export function getStaticPaths() {
  return projectsData.map(project => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const isNotichilec = project.slug === 'notichilec';
---

<Layout title={`${project.title} | Caso de Estudio`}>
  {isNotichilec ? (
    <NotichilecCaseStudy project={project} />
  ) : (
    <ProjectCaseStudy project={project} />
  )}
</Layout>
