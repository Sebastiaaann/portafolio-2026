---
interface Props {
	title?: string;
	description?: string;
}

const { 
  title = "Portafolio 2026 - Sebastian Almonacid", 
  description = "Portafolio de Sebastian Almonacid, frontend developer y optimizador." 
} = Astro.props;

import '../index.css';
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="es">
	<head>
		<ClientRouter />
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body class="min-h-screen bg-black text-zinc-900 font-sans selection:bg-zinc-200 selection:text-zinc-900 antialiased">
		<a
			href="#main-content"
			class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-zinc-900 focus:text-white focus:px-4 focus:py-2 focus:rounded-md focus:shadow-lg focus:transition-colors"
		>
			Ir al contenido principal
		</a>
		<div vaul-drawer-wrapper class="min-h-screen bg-white bg-dot-pattern flex flex-col relative transition-transform duration-500">
			<Header transition:persist />
			<main id="main-content">
				<slot />
			</main>
			<Footer />
		</div>
	</body>
</html>
