---
import type { CaseStudySection } from '../data/projects';

interface Props {
  section: CaseStudySection;
  projectTitle: string;
  index: number;
}

const { section, projectTitle, index } = Astro.props;
---

{(section.type === 'hero' || section.type === 'tech') && (
  <section class="section-reveal max-w-2xl mx-auto text-center py-16 md:py-24 px-6">
    <div class="w-8 h-[1px] bg-zinc-200 mx-auto mb-6" />
    <h2 class="font-serif text-3xl md:text-4xl font-bold text-zinc-900 tracking-tight text-balance mb-4">
      {section.title}
    </h2>
    {section.description && (
      <p class="text-lg text-zinc-500 leading-relaxed text-pretty">
        {section.description}
      </p>
    )}
  </section>
)}

{section.type === 'showcase' && (
  <section class="section-reveal" style={`animation-delay: ${index * 80}ms`}>
    <div class={`flex flex-col ${index % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'} gap-12 md:gap-24 max-w-7xl mx-auto px-6 items-start`}>
      {/* Content Side */}
      <div class="md:w-[40%] md:pt-8">
        <div class="w-8 h-[1px] bg-zinc-200 mb-6" />
        {section.title && (
          <h2 class="font-serif text-3xl md:text-4xl font-bold text-zinc-900 tracking-tight text-balance mb-4">
            {section.title}
          </h2>
        )}
        {section.description && (
          <p class="text-lg text-zinc-500 leading-relaxed text-pretty">
            {section.description}
          </p>
        )}
      </div>

      {/* Image Side */}
      {(section.image || section.images) && (
        <div class="md:w-[60%] w-full">
          {section.image && (
            <div class="rounded-2xl md:rounded-3xl overflow-hidden bg-zinc-50/50 border border-zinc-200/50 shadow-sm group">
              <img
                src={section.image}
                alt={section.title || projectTitle}
                class="w-full h-auto object-cover transition-transform duration-300 group-hover:scale-[1.02]"
                loading="lazy"
                decoding="async"
                width="800"
                height="500"
              />
            </div>
          )}

          {section.images && section.images.length > 0 && (
            <div class="rounded-2xl md:rounded-3xl overflow-hidden bg-zinc-50/50 border border-zinc-200/50 p-4 sm:p-8 space-y-4">
              {section.images.map((img, i) => (
                <div class="rounded-xl overflow-hidden">
                  <img
                    src={img}
                    alt={`${section.title || projectTitle} - ${i + 1}`}
                    class="w-full h-auto object-cover"
                    loading="lazy"
                    decoding="async"
                    width="800"
                    height="500"
                  />
                </div>
              ))}
            </div>
          )}
        </div>
      )}
    </div>
  </section>
)}
