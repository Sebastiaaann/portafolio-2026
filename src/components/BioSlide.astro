---
import { Github, Linkedin } from 'lucide-react';
import CopyEmailButton from './react/CopyEmailButton';
---

<section class="section slide section-1" id="hero-section">
  <div class="section-content w-full h-full flex flex-col items-center relative">
    
    <div class="section-inner w-full flex flex-col items-center">
      <div class="max-w-3xl mx-auto px-6 pb-24 relative flex flex-col items-center antialiased text-center w-full">
        
        {/* Heading & Avatar */}
        <div class="mt-6 mb-8 flex w-full max-w-[520px] flex-col items-center text-center">
          {/* Avatar */}
          <div class="h-28 w-28 rounded-full overflow-hidden border border-zinc-200 shadow-sm ring-1 ring-black/5 ring-inset mb-6" transition:name="avatar">
            <img src="/png.jpeg" alt="Sebastian Almonacid" class="w-full h-full object-cover object-[center_60%]" />
          </div>

          <div class="flex flex-col items-center gap-2">
            <h1 class="font-serif text-4xl md:text-5xl font-bold text-zinc-900 tracking-tight text-balance" transition:name="title">
              Sebastian Almonacid
            </h1>
            <p class="font-sans text-xl md:text-2xl font-medium text-zinc-700 text-pretty">
              Frontend Developer
            </p>
          </div>
        </div>

        <div class="flex w-full flex-col items-center gap-6">
          {/* Paper Style Bio Block */}
            <div class="mt-6 mx-auto flex w-full max-w-[520px] flex-col gap-4 text-left">
            {/* Header */}
            <div class="items-center flex gap-1.5 w-full">
              <div class="text-[16px] leading-snug text-[#171717] font-sans font-medium">
                Sebastian, <span class="text-[#737373] font-normal">Frontend Developer</span>
              </div>
              <div class="mt-0.5">
                <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" color="#2B7FFF">
                  <path d="M6 3C4.343 3 3 4.343 3 6C3 7.306 3.835 8.417 5 8.829V15.171C3.835 15.582 3 16.694 3 18C3 19.657 4.343 21 6 21C7.657 21 9 19.657 9 18C9 16.694 8.165 15.582 7 15.171V8.829C8.165 8.417 9 7.306 9 6C9 4.343 7.657 3 6 3Z" fill="#2B7FFF" />
                  <path d="M14.414 5L14.707 4.707C15.098 4.317 15.098 3.683 14.707 3.293C14.317 2.902 13.683 2.902 13.293 3.293L11.293 5.293C10.902 5.683 10.902 6.317 11.293 6.707L13.293 8.707C13.683 9.098 14.317 9.098 14.707 8.707C15.098 8.317 15.098 7.683 14.707 7.293L14.414 7H15C16.105 7 17 7.895 17 9V15.171C15.835 15.582 15 16.694 15 18C15 19.657 16.343 21 18 21C19.657 21 21 19.657 21 18C21 16.694 20.165 15.582 19 15.171V9C19 6.791 17.209 5 15 5H14.414Z" fill="#2B7FFF" />
                </svg>
              </div>
            </div>
            
            {/* Body */}
            <div class="flex flex-col gap-1.5">
              <div class="text-[16px] leading-[1.6] text-[#737373] font-sans text-pretty">
                Soy un <span class="text-[#171717] font-medium">Ingeniero en Informática</span> y desarrollador Frontend, con foco en interfaces escalables, <span class="text-pink-500 italic font-serif">arquitectura de componentes</span> y <span class="font-serif font-medium text-[#171717]">experiencia de usuario</span>.
              </div>
              <div class="text-[16px] leading-[1.6] text-[#737373] font-sans text-pretty">
                Me desenvuelvo entre diseño y desarrollo, integrando criterio visual y ejecución técnica para construir 
                <span class="inline-flex items-baseline gap-1 text-[#171717] underline decoration-1 underline-offset-2 mx-1 font-medium">
                  <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" color="#171717" class="self-center flex-shrink-0">
                    <path d="M2 8C2 5.791 3.791 4 6 4H18C20.209 4 22 5.791 22 8V12.25C22 12.802 21.552 13.25 21 13.25C20.448 13.25 20 12.802 20 12.25V8C20 6.895 19.105 6 18 6H6C4.895 6 4 6.895 4 8V17C4 18.105 4.895 19 6 19H12C12.552 19 13 19.448 13 20C13 20.552 12.552 21 12 21H6C3.791 21 2 19.209 2 17V8Z" fill="#171717"/>
                    <path d="M5.5 8.75C5.5 9.44 6.06 10 6.75 10C7.44 10 8 9.44 8 8.75C8 8.06 7.44 7.5 6.75 7.5C6.06 7.5 5.5 8.06 5.5 8.75Z" fill="#171717"/>
                    <path d="M9 8.75C9 9.44 9.56 10 10.25 10C10.94 10 11.5 9.44 11.5 8.75C11.5 8.06 10.94 7.5 10.25 7.5C9.56 7.5 9 8.06 9 8.75Z" fill="#171717"/>
                    <path d="M12.5 8.75C12.5 9.44 13.06 10 13.75 10C14.44 10 15 9.44 15 8.75C15 8.06 14.44 7.5 13.75 7.5C13.06 7.5 12.5 8.06 12.5 8.75Z" fill="#171717"/>
                    <path d="M15.794 14.544C15.44 14.435 15.055 14.531 14.793 14.793C14.531 15.055 14.435 15.44 14.544 15.794L16.544 22.294C16.664 22.685 17.01 22.963 17.418 22.997C17.825 23.03 18.212 22.813 18.395 22.447L19.745 19.745L22.447 18.395C22.813 18.212 23.03 17.825 22.997 17.418C22.963 17.01 22.685 16.664 22.294 16.544L15.794 14.544Z" fill="#171717"/>
                  </svg>
                  soluciones mantenibles
                </span> 
                y centradas en el usuario.
              </div>
            </div>

            {/* Buttons */}
            <div class="items-center flex flex-wrap justify-start gap-2 mt-2 pointer-events-auto">
              <a href="https://wa.me/56956663005" target="_blank" rel="noopener noreferrer" class="items-center flex shrink-0 h-9 justify-center rounded-full pr-3 pl-2.5 gap-1.5 bg-[#171717] border border-solid border-[#00000000] hover:bg-zinc-800 transition-colors">
                <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" color="#FAFAFA" class="flex-shrink-0">
                  <path d="M1.581 10.679C7.756 7.998 11.873 6.231 13.931 5.377C19.815 2.938 21.036 2.514 21.834 2.5C22.009 2.497 22.4 2.54 22.654 2.746C22.866 2.919 22.926 3.153 22.956 3.318C22.982 3.482 23.019 3.856 22.989 4.148C22.671 7.487 21.291 15.587 20.59 19.326C20.295 20.908 19.709 21.439 19.143 21.491C17.912 21.603 16.979 20.68 15.788 19.902C13.925 18.684 12.872 17.926 11.062 16.738C8.971 15.364 10.327 14.609 11.519 13.375C11.83 13.052 17.25 8.139 17.353 7.693C17.366 7.638 17.38 7.43 17.254 7.32C17.131 7.211 16.949 7.248 16.817 7.278C16.628 7.32 13.653 9.282 7.882 13.164C7.038 13.742 6.273 14.024 5.585 14.009C4.831 13.993 3.375 13.583 2.292 13.233C0.969 12.803 -0.087 12.576 0.006 11.846C0.052 11.466 0.578 11.077 1.581 10.679Z" fill="#FAFAFA" />
                </svg>
                <div class="text-[14px] leading-snug w-max text-[#FAFAFA] font-sans shrink-0 font-medium">
                  Enviar mensaje
                </div>
              </a>
              
              <CopyEmailButton client:visible />

              <a href="https://github.com/Sebastiaaann" target="_blank" rel="noopener noreferrer" class="items-center flex shrink-0 h-9 w-9 justify-center rounded-full bg-[#F5F5F5] text-[#171717] hover:bg-zinc-200 transition-colors ml-1">
                <Github className="w-4 h-4" />
              </a>
              <a href="https://www.linkedin.com/in/sebastian-almonacid-santana-63b980264/" target="_blank" rel="noopener noreferrer" class="items-center flex shrink-0 h-9 w-9 justify-center rounded-full bg-[#F5F5F5] text-[#171717] hover:bg-zinc-200 transition-colors">
                <Linkedin className="w-4 h-4" />
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
