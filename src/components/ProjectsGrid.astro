---
import { projectsData } from "../data/projects";
---

<section class="w-full mx-auto px-6 lg:px-20 pb-32">
  <div class="columns-1 md:columns-2 lg:columns-3 gap-5 lg:gap-6 space-y-5 lg:space-y-6">
    {projectsData.map((project, index) => (
      <a
        href={project.caseStudy ? `/proyectos/${project.slug}` : project.link}
        data-astro-prefetch={project.caseStudy ? true : undefined}
        target={!project.caseStudy ? "_blank" : undefined}
        rel={!project.caseStudy ? "noopener noreferrer" : undefined}
        class="group relative block break-inside-avoid overflow-hidden rounded-lg bg-zinc-900 card-reveal"
        style={`animation-delay: ${index * 80}ms`}
      >
        {/* Full-bleed image */}
        <div class="relative aspect-[4/3] overflow-hidden">
          {project.image ? (
            <img
              src={project.image}
              alt={project.title}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-110"
              transition:name={`project-image-${project.slug}`}
              loading="lazy"
              decoding="async"
            />
          ) : (
            <div class="absolute inset-0 bg-zinc-800" />
          )}

          {/* Gradient overlay — always present, stronger on hover */}
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent transition-opacity duration-500 group-hover:opacity-100 opacity-60" />

          {/* Category badge — top left */}
          <div class="absolute top-3 left-3 z-10">
            <span class="inline-flex items-center rounded-full bg-white/10 backdrop-blur-md px-2.5 py-1 text-[10px] font-medium text-white/90 tracking-wide uppercase border border-white/10 transition-all duration-300 group-hover:bg-white/20 group-hover:border-white/20">
              {project.category}
            </span>
          </div>
        </div>

        {/* Info overlay — slides up on hover */}
        <div class="absolute inset-x-0 bottom-0 z-10 p-4 pt-16 transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] translate-y-2 group-hover:translate-y-0">
          {/* Decorative line */}
          <div class="w-6 h-[1px] bg-white/40 mb-3 transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] w-0 group-hover:w-6" />

          {/* Title — display font */}
          <h3
            class="font-display text-2xl font-semibold text-white tracking-tight leading-[1.1] text-balance transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] translate-y-1 group-hover:translate-y-0"
            transition:name={`project-title-${project.slug}`}
          >
            {project.title}
          </h3>

          {/* Description — revealed on hover */}
          <p class="mt-2 text-sm text-white/70 leading-relaxed text-balance max-h-0 overflow-hidden opacity-0 transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:max-h-24 group-hover:opacity-100 group-hover:mt-2 line-clamp-3">
            {project.description}
          </p>

          {/* Date — bottom right */}
          {project.date && (
            <div class="mt-3 flex items-center justify-between">
              <span class="text-[11px] text-white/50 tabular-nums tracking-wide">
                {project.date}
              </span>
              {/* Arrow indicator */}
              <svg class="w-4 h-4 text-white/60 transition-all duration-300 -translate-x-2 opacity-0 group-hover:translate-x-0 group-hover:opacity-100" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </div>
          )}
        </div>
      </a>
    ))}
  </div>
</section>
