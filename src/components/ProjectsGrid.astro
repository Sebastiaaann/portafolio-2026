---
import { projectsData } from "../data/projects";
---

<section class="w-full max-w-[1879px] mx-auto px-6 lg:px-20 font-sans">
  <div class="columns-1 md:columns-2 lg:columns-3 gap-4">
    {projectsData.map((project) => (
      <a
        href={project.caseStudy ? `/proyectos/${project.slug}` : project.link}
        data-astro-prefetch={project.caseStudy ? true : undefined}
        target={!project.caseStudy ? "_blank" : undefined}
        rel={!project.caseStudy ? "noopener noreferrer" : undefined}
        class="group mb-4 flex break-inside-avoid flex-col overflow-hidden rounded-[14px] border border-zinc-200 bg-zinc-50 transition-colors hover:border-zinc-300"
      >
        {/* Image - takes up main space */}
        <div class="w-full overflow-hidden bg-zinc-100">
          {project.image ? (
            <img 
              src={project.image} 
              alt={project.title} 
              class="w-full h-auto object-cover group-hover:scale-105 transition-transform duration-700 ease-[cubic-bezier(0.23,1,0.32,1)]"
              transition:name={`project-image-${project.slug}`}
              loading="lazy"
            />
          ) : (
            <div class="w-full aspect-video bg-zinc-100" />
          )}
        </div>

        {/* Minimal Footer */}
        <div class="px-4 py-3 flex justify-between items-center bg-zinc-50 border-t border-zinc-100">
          <h3 
            class="font-sans text-sm font-medium text-zinc-900 leading-none"
            transition:name={`project-title-${project.slug}`}
          >
            {project.title}
          </h3>
          {project.date && (
            <span class="font-sans text-xs text-zinc-500 tabular-nums">
              {project.date}
            </span>
          )}
        </div>
      </a>
    ))}
  </div>
</section>
